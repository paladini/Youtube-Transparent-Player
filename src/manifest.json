{
	"name": "Youtube Transparent Player",
	"short_name": "YT New Player",
	"description": "Enable the new Youtube Transparent Player.",
	"author": "Fernando Paladini",
	"homepage_url" : "https://github.com/paladini/Youtube-Transparent-Player",
	"version": "0.4.0",
	"permissions": [
		"cookies"
	],
	"host_permissions": [
		"*://*.youtube.com/*"
	],
	"background": {
		"service_worker": "js/background.js"
	},
	"icons": {
		"24": "images/icon24.png",
		"48": "images/icon48.png",
		"128": "images/icon128.png"
	},
	"options_ui": {
		"page": "options.html",
		"chrome_style": true
	},
	"manifest_version": 3
}

